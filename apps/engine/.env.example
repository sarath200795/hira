# Shared Firebase web config for the unified engine (ONE project for all apps).
# Copy to apps/engine/.env and fill in from Firebase Console → Project settings.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional: named Firestore database id (defaults to "(default)")
VITE_FIREBASE_DB_ID=

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isUser(uid) { return signedIn() && request.auth.uid == uid; }
    function myOrgId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId;
    }

    // Public org index — read pre-auth for the signup dropdown; writes require auth.
    match /orgIndex/{slug} {
      allow read: if true;
      allow write: if signedIn();
    }

    // User profiles — any signed-in user can read (needed for member lists);
    // a user may create/update only their own doc.
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isUser(uid);
    }

    // Organizations — any signed-in user may create one; reads/updates limited to
    // signed-in users. Assessments are scoped to the caller's org.
    match /organizations/{orgId} {
      allow create: if signedIn();
      allow read, update, delete: if signedIn();

      match /assessments/{docId} {
        allow read, write: if signedIn() && orgId == myOrgId();
      }

      // Append-only activity log (audit trail).
      match /activity/{docId} {
        allow read, create: if signedIn() && orgId == myOrgId();
        allow update, delete: if false;
      }
    }
  }
}

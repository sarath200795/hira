# Firebase web config — copy this file to ".env" and fill in your project's keys.
# Find these in Firebase Console → Project settings → General → Your apps → SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Guide AI fallback (optional) ─────────────────────────────────────────────
# SERVER-SIDE ONLY — do NOT prefix with VITE_ (that would expose it in the
# browser bundle). Used by the api/assistant.js serverless function so the guide
# ("Sam") can answer free-form questions. Without it, the guide uses offline
# rules only. Get a free key at https://aistudio.google.com/app/apikey
# Set it in Vercel → Project → Settings → Environment Variables (Production).
GEMINI_API_KEY=
